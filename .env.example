# ============================================
  # MATCHA ON ICE - Variáveis de Ambiente
  # ============================================

  # Marco T0 - Validação Técnica do Stripe
  # ============================================

  # Stripe Secret Key (obtenha em: Stripe Dashboard → Developers → API keys)
  # Exemplo: sk_test_51A...
  STRIPE_SECRET_KEY=

  # Stripe Webhook Secret (obtenha após criar o webhook no Stripe)
  # Exemplo: whsec_...
  STRIPE_WEBHOOK_SECRET=

  # ============================================
  # Futuro - Marco M1+ (não necessário agora)
  # ============================================

  # PostgreSQL Database URL (fornecido automaticamente pelo Replit)
  # DATABASE_URL=postgresql://...

  # JWT Secret para autenticação admin
  # JWT_SECRET=

  # Session Secret
  # SESSION_SECRET=

  # Email Service (SendGrid, Resend, etc)
  # EMAIL_API_KEY=
  # EMAIL_FROM=noreply@matchaonice.com
  